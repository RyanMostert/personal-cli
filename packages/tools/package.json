{
  "name": "@personal-cli/tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --platform node --external fast-glob",
    "dev": "tsup src/index.ts --format esm --dts --watch --platform node --external fast-glob",
    "clean": "rm -rf dist"
  },
"dependencies": {
    "@personal-cli/mcp-client": "workspace:*",
    "@personal-cli/shared": "workspace:*",
    "ai": "^6.0.104",
    "fast-glob": "^3.3.0",
    "minimatch": "^10.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  }
}