{
  "name": "@personal-cli/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --platform node --external @personal-cli/tools --external @personal-cli/shared",
    "dev": "tsup src/index.ts --format esm --dts --watch --platform node --external @personal-cli/tools --external @personal-cli/shared",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.72",
    "@ai-sdk/anthropic": "^3.0.49",
    "@ai-sdk/azure": "^3.0.40",
    "@ai-sdk/google": "^3.0.34",
    "@ai-sdk/google-vertex": "^4.0.71",
    "@ai-sdk/groq": "^3.0.26",
    "@ai-sdk/mistral": "^3.0.21",
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/xai": "^3.0.60",
    "@aws-sdk/credential-providers": "^3.1000.0",
    "@personal-cli/shared": "workspace:*",
    "ai": "^6.0.104",
    "google-auth-library": "^10.6.1",
    "yaml": "^2.8.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  }
}
