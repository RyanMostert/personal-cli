{
  "name": "@personal-cli/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "pcli": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsup src/bin.ts src/app.tsx --format esm --dts --external ink react",
    "dev": "tsup src/bin.ts src/app.tsx --format esm --watch --external ink react",
    "start": "node dist/bin.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@personal-cli/core": "workspace:*",
    "@personal-cli/shared": "workspace:*",
    "@personal-cli/tools": "workspace:*",
    "@shikijs/cli": "^4.0.0",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "react": "^19.2.4",
    "shiki": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  }
}
