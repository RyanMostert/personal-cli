{
  "name": "@personal-cli/zen-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "zen-mcp-server": "./dist/main.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/main.ts --format esm --dts --platform node",
